{
    "extends": "@tsconfig/strictest",
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "rootDir": "./",
        "noEmit": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["vite/client", "react", "react-dom", "bun", "unplugin-icons/types/react"]
    },
    "include": ["./src/**/*", "./*.ts"]
}
